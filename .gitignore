# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Local knowledge base (e.g. Obsidian vault; not part of the app)
knowledge/
*.swp
*.swo

# Temp files
*.tmp
*.bak

# Secrets (never commit these)
.env
*.key
secrets/
config/supabase.env
config/mcp.secrets.env
frontend/.env
frontend/.env.local

# Next.js build cache
.next/
out/

# Tooling caches
.vite/

# Node (if any scripts use it)
node_modules/

# Python
__pycache__/
*.pyc
.venv/

# Price history cache (large derived data — regenerated by preload-history.py)
data/price-history/

# Agent scratch (canonical state is Supabase; do not commit generated trees)
data/agent-cache/**
!data/agent-cache/.gitkeep

# Deprecated repo path (never commit — canonical state is Supabase)
outputs/

# Dashboard data JSON (generated by update_tearsheet.py — not committed)
frontend/public/dashboard-data.json
